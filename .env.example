# X (Twitter) transport method — "scraper" (free) or "api" (paid)
X_READ_METHOD=scraper
X_WRITE_METHOD=scraper

# X username to scrape
X_USERNAME=wifsimster

# Session tokens for scraper mode — extract from browser cookies after login
# 1. Log in to x.com in your browser
# 2. Open DevTools → Application → Cookies → https://x.com
# 3. Copy the values of "auth_token" and "ct0"
X_SESSION_AUTH_TOKEN=
X_SESSION_CSRF_TOKEN=

# X API credentials — only needed if X_READ_METHOD=api or X_WRITE_METHOD=api
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# Optional: override GraphQL operation IDs when X changes them
# X_GQL_USER_BY_SCREEN_NAME_ID=qW5u-DAuXpMEG0zA1F7UGQ
# X_GQL_USER_TWEETS_ID=E3opETHurmVJflFsUBVuUQ
# X_GQL_CREATE_TWEET_ID=bDE2rBtZb3uyrczSZ_pI9g

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional
# CLAUDE_MODEL=claude-sonnet-4-20250514
# TWEETS_LOOKBACK_DAYS=7
# MAX_TWEETS=200
# DRY_RUN=true
