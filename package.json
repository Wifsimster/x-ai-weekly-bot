{
  "name": "x-ai-weekly-bot",
  "version": "1.0.0",
  "description": "Weekly AI news bot that scrapes X timeline and posts AI-related summaries",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "twitter-api-v2": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.54.0"
  }
}
